---
import Layout from '../layouts/Layout.astro';

import Breadcrumbs from '../components/Breadcrumbs.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

import LinksGrid from '../components/blog/LinksGrid.astro';


const stylesheets = [
	'https://fonts.googleapis.com/css?family=Open+Sans:300,300i,400,400i,600,600i,700,700i|Raleway:300,300i,400,400i,500,500i,600,600i,700,700i|Poppins:300,300i,400,400i,500,500i,600,600i,700,700i',
	'/assets/vendor/aos/aos.css',
	'/assets/vendor/bootstrap/css/bootstrap.min.css',
	'/assets/vendor/bootstrap-icons/bootstrap-icons.css',
	'/assets/vendor/boxicons/css/boxicons.min.css',
	'/assets/vendor/glightbox/css/glightbox.min.css',
	'/assets/vendor/swiper/swiper-bundle.min.css',
	'/assets/css/style.css',
	'/assets/css/global.css',
];

const scripts = [
	'/assets/vendor/purecounter/purecounter_vanilla.js',
	'/assets/vendor/aos/aos.js',
	'/assets/vendor/bootstrap/js/bootstrap.bundle.min.js',
	'/assets/vendor/glightbox/js/glightbox.min.js',
	'/assets/vendor/isotope-layout/isotope.pkgd.min.js',
	'/assets/vendor/swiper/swiper-bundle.min.js',
	'/assets/vendor/typed.js/typed.min.js',
	'/assets/vendor/waypoints/noframework.waypoints.js',
	'/assets/js/main.js',
];

const author = 'AlejandroCR<contacto@alejandrocr.co>';
const keywords = 'portafolio,personal,alejandro,alejandrocr,desarrollador,blog,tecnología,historias';
const title = '¡Sitio web de AlejandroCR! | Blog';
const description = '¡Bienvenidos a mi blog! '
	+ 'Aquí encontrarás artículos sobre tecnología e historias de mi autoria.'
---

<Layout
	author={author}
	description={description}
	keywords={keywords}
	title={title}
	stylesheets={stylesheets}
	scripts={scripts}>

  <!-- MOBILE NAV TOGGLE BUTTON -->
  <i class="bi bi-list mobile-nav-toggle d-xl-none"></i>

  <Header></Header>

  <main id="main">

    <Breadcrumbs
			links={[
				{ href: '/', text: 'Inicio' },
			]}
			current="blog"
		></Breadcrumbs>

		<div class="container">
			<LinksGrid></LinksGrid>
		</div>

  </main> <!-- End #main -->

  <Footer></Footer>

	<!-- BACK TO TOP BUTTON -->
  <a href="#" class="back-to-top d-flex align-items-center justify-content-center"><i class="bi bi-arrow-up-short"></i></a>

</Layout>
