---
export interface Props {
  aosDelay: number;
  href: string;
  iconClass: string;
  title: string;
}

const { aosDelay, href, iconClass, title } = Astro.props;
---

<div class="col-lg-4 col-md-6 icon-box" data-aos="fade-up" data-aos-delay={aosDelay}>
  <div class="icon"><i class={iconClass}></i></div>
  <h4 class="title"><a href={href}>{title}</a></h4>
  <p class="description">
    <slot></slot>
  </p>
</div>
